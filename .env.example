# Copy to .env.local and fill in your keys (never commit .env.local).

# --- AI (/api/ai) ---
# Local dev: ollama last is fine. On Vercel use cloud only, e.g.:
#   AI_PROVIDER_ORDER=groq,gemini
AI_PROVIDER_ORDER=groq,gemini,ollama

# Groq (https://console.groq.com)
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Local Ollama (not available from Vercel servers)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# --- Optional ingest proxy (/api/ingest) ---
# Local FastAPI etc., no trailing slash. Unset in production if unused.
# INGEST_API_BASE_URL=http://127.0.0.1:8000

# --- Firebase Configuration ---
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# --- Redis Configuration (Optional) ---
REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://user:password@host:port

# --- Authentication & Security ---
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
RATE_LIMIT_SECRET=your-rate-limit-secret-key

# --- Supabase Configuration ---
# Public variables (exposed to browser - use anon key)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side variables (never exposed to browser - use service role key)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- NextAuth Configuration ---
NEXTAUTH_URL=https://your-domain.vercel.app
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

# --- Monitoring & Error Tracking ---
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# --- Application Configuration ---
PORT=3000
HOST=0.0.0.0
NEXT_PUBLIC_API_URL=http://roundhouse.proxy.rlwy.net:39487
NEXT_PUBLIC_APP_VERSION=1.0.0
NODE_ENV=production

# --- Gamification Settings ---
XP_BASE_AMOUNT=10
XP_MULTIPLIER=1.0
MAX_DAILY_XP=1000
STREAK_RESET_HOURS=24
ANTI_CHEAT_ENABLED=true

# --- Cache Configuration ---
CACHE_TTL=300
CACHE_MAX_ENTRIES=1000

# --- Background Jobs ---
ENABLE_BACKGROUND_JOBS=true
JOB_CONCURRENCY=5

# --- Analytics ---
ANALYTICS_RETENTION_DAYS=90
INSIGHTS_GENERATION_INTERVAL=4
