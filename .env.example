# Copy to .env.local and fill in your keys (never commit .env.local).

# Try providers in this order (comma-separated): groq, gemini, ollama
AI_PROVIDER_ORDER=groq,gemini,ollama

# Groq (https://console.groq.com)
GROQ_API_KEY=
# Optional override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
# Optional (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Local Ollama — install: irm https://ollama.com/install.ps1 | iex
# Then: ollama pull llama3.2
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
