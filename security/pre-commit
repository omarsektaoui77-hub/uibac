#!/bin/sh
# ZeroLeak Security Engine - Pre-Commit Hook
# This hook blocks commits that contain secrets or high-risk changes

echo "🔍 ZeroLeak Security Scan..."

# Run the scanner on staged files
node security/scan-secrets.js --staged --silent

# Check exit code
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ BLOCKED: Secrets detected in staged files"
  echo "👉 To fix:"
  echo "   1. Review and remove the secrets"
  echo "   2. Or run: node security/scan-secrets.js --fix"
  echo "   3. Commit again"
  echo ""
  exit 1
fi

# Run AppSec scanner
node security/appsec-scan.js --silent

# Check exit code
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ BLOCKED: AppSec issues detected in staged files"
  echo "👉 Review the suspicious patterns and fix"
  echo ""
  exit 1
fi

# Run Brain analysis
node security/brain.js --staged --silent

# Check exit code
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ BLOCKED: High-risk change detected by Brain"
  echo "👉 Review the behavioral risk and get approval"
  echo ""
  exit 1
fi

# Run Autonomous Security System
node security/autonomous.js --staged --silent

# Check exit code
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ BLOCKED: Autonomous Security System blocked this commit"
  echo ""
  exit 1
fi

echo "✅ All security checks passed - commit allowed"
